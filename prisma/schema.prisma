generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  REPLIED
  INTERESTED
  NOT_INTERESTED
  CONVERTED
  BOUNCED
  UNSUBSCRIBED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  FAILED
  DELIVERED
  READ
  REPLIED
  UNSUBSCRIBED
  CONVERTED
  BOUNCED
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum EventType {
  CAMPAIGN_CREATED
  CAMPAIGN_STARTED
  CAMPAIGN_PAUSED
  CAMPAIGN_COMPLETED
  LEAD_IMPORTED
  LEAD_UPDATED
  LEAD_UNSUBSCRIBED
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  MESSAGE_QUEUED
  MESSAGE_SENT
  MESSAGE_FAILED
  MESSAGE_DELIVERED
  MESSAGE_READ
  REPLY_RECEIVED
  CONVERSION_RECORDED
}

enum ConversationSource {
  CAMPAIGN
  MANUAL
  WEBHOOK
}

model User {
  id                   String               @id @default(uuid())
  companyName          String
  email                String               @unique
  passwordHash         String
  role                 UserRole             @default(OWNER)
  isActive             Boolean              @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  
  sessions             Session[]
  whatsappAccounts     WhatsappAccount[]
  leads                Lead[]
  leadTags             LeadTag[]
  templates            Template[]
  campaigns            Campaign[]
  messages             Message[]
  conversations        Conversation[]
  activityLogs         ActivityLog[]
  analyticsSnapshots   AnalyticsSnapshot[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  tokenHash   String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model WhatsappAccount {
  id                      String   @id @default(uuid())
  userId                  String
  accountName             String
  phoneNumberId           String   @unique
  businessAccountId       String
  accessTokenEncrypted    String
  webhookVerifyTokenEncrypted String?
  displayPhoneNumber      String?
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads                   Lead[]
  campaigns               Campaign[]
  messages                Message[]
  conversations           Conversation[]
  
  @@index([userId])
  @@index([businessAccountId])
}

model Lead {
  id                 String        @id @default(uuid())
  userId             String
  whatsappAccountId  String?
  phoneNumber        String
  firstName          String?
  lastName           String?
  email              String?
  source             String?
  customFieldsJson   String?
  optIn              Boolean       @default(true)
  unsubscribed       Boolean       @default(false)
  unsubscribedAt     DateTime?
  status             LeadStatus    @default(NEW)
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount    WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id], onDelete: SetNull)
  campaignLeads      CampaignLead[]
  messages           Message[]
  conversations      Conversation[]
  conversationMessages ConversationMessage[]
  activityLogs       ActivityLog[]
  leadTagAssignments LeadTagAssignment[]
  
  @@unique([userId, phoneNumber])
  @@index([userId])
  @@index([phoneNumber])
  @@index([status])
  @@index([unsubscribed])
  @@index([optIn])
}

model LeadTag {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("#6b7280")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  leadTagAssignments LeadTagAssignment[]
  
  @@unique([userId, name])
  @@index([userId])
}

model LeadTagAssignment {
  id        String   @id @default(uuid())
  leadId    String
  tagId     String
  createdAt DateTime @default(now())
  
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag       LeadTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  @@unique([leadId, tagId])
  @@index([leadId])
  @@index([tagId])
}

model Template {
  id                   String   @id @default(uuid())
  userId               String
  name                 String
  body                 String
  placeholderSchemaJson String?
  previewExampleJson    String?
  isArchived           Boolean  @default(false)
  version              Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns            Campaign[]
  
  @@unique([userId, name, version])
  @@index([userId])
}

model Campaign {
  id                    String        @id @default(uuid())
  userId                String
  whatsappAccountId     String
  templateId            String
  name                  String
  description           String?
  status                CampaignStatus @default(DRAFT)
  scheduledAt           DateTime?
  startedAt             DateTime?
  completedAt           DateTime?
  batchSize             Int           @default(10)
  delayInSeconds        Int           @default(5)
  totalRecipients       Int           @default(0)
  totalQueued          Int           @default(0)
  totalSent            Int           @default(0)
  totalDelivered       Int           @default(0)
  totalRead            Int           @default(0)
  totalReplied         Int           @default(0)
  totalConverted       Int           @default(0)
  totalFailed          Int           @default(0)
  totalUnsubscribed    Int           @default(0)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount      WhatsappAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  template             Template      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  campaignLeads        CampaignLead[]
  messages             Message[]
  activityLogs         ActivityLog[]
  analyticsSnapshots   AnalyticsSnapshot[]
  
  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

model CampaignLead {
  id              String     @id @default(uuid())
  campaignId      String
  leadId          String
  status          MessageStatus @default(QUEUED)
  excludedReason  String?
  scheduledFor    DateTime?
  processedAt     DateTime?
  attemptCount    Int        @default(0)
  lastAttemptAt   DateTime?
  nextAttemptAt   DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  campaign        Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead            Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages        Message[]
  
  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
}

model Message {
  id                   String        @id @default(uuid())
  userId               String
  whatsappAccountId    String
  campaignId           String?
  leadId               String
  campaignLeadId       String?
  direction            MessageDirection
  status               MessageStatus @default(QUEUED)
  whatsappMessageId    String?
  templateSnapshot     String?
  renderedBody         String?
  failureReason        String?
  retryCount           Int           @default(0)
  lastRetryAt          DateTime?
  queuedAt             DateTime?
  sendingAt            DateTime?
  sentAt               DateTime?
  deliveredAt          DateTime?
  readAt               DateTime?
  repliedAt            DateTime?
  bouncedAt            DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  whatsappAccount      WhatsappAccount @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  campaign             Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  lead                 Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaignLead         CampaignLead? @relation(fields: [campaignLeadId], references: [id], onDelete: SetNull)
  messageEvents        MessageEvent[]
  
  @@unique([campaignId, leadId, direction])
  @@unique([whatsappMessageId])
  @@index([campaignId])
  @@index([leadId])
  @@index([status])
  @@index([direction])
  @@index([sentAt])
}

model MessageEvent {
  id               String   @id @default(uuid())
  messageId        String
  eventType        EventType
  eventPayloadJson String?
  occurredAt       DateTime
  createdAt        DateTime @default(now())
  
  message          Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  @@index([messageId])
  @@index([occurredAt])
}

model Conversation {
  id                 String             @id @default(uuid())
  userId             String
  leadId             String
  whatsappAccountId  String
  source             ConversationSource @default(MANUAL)
  lastMessageAt      DateTime          @default(now())
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead               Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  whatsappAccount    WhatsappAccount    @relation(fields: [whatsappAccountId], references: [id], onDelete: Cascade)
  conversationMessages ConversationMessage[]
  
  @@unique([userId, leadId, whatsappAccountId])
  @@index([leadId])
  @@index([lastMessageAt])
}

model ConversationMessage {
  id                 String        @id @default(uuid())
  conversationId     String
  leadId             String
  campaignId         String?
  direction          MessageDirection
  body               String
  whatsappMessageId  String?
  messageId          String?
  sentAt             DateTime?
  receivedAt         DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  
  conversation       Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead               Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([leadId])
}

model ActivityLog {
  id            String    @id @default(uuid())
  userId        String
  leadId        String?
  campaignId    String?
  messageId     String?
  eventType     EventType
  description   String
  metadataJson  String?
  createdAt     DateTime  @default(now())
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead          Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  campaign      Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([leadId])
  @@index([campaignId])
}

model AnalyticsSnapshot {
  id               String   @id @default(uuid())
  userId           String
  campaignId       String
  snapshotDate     DateTime @db.Date
  totalRecipients  Int      @default(0)
  totalSent        Int      @default(0)
  totalDelivered   Int      @default(0)
  totalRead        Int      @default(0)
  totalReplied     Int      @default(0)
  totalConverted   Int      @default(0)
  totalFailed      Int      @default(0)
  totalUnsubscribed Int     @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  
  @@unique([campaignId, snapshotDate])
  @@index([snapshotDate])
}
